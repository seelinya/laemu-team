# ─── Datenbank ────────────────────────────────────────────────────────────────
# Standard: lokale SQLite-Datei (kein Setup nötig).
# Für Produktion auf Postgres umstellen, z.B.:
#   DATABASE_URL="postgresql://user:pass@host:5432/laemu_team?schema=public"
# und in prisma/schema.prisma provider = "postgresql" setzen.
DATABASE_URL="file:./dev.db"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Geheimer Schlüssel zum Signieren der Session-Cookies. UNBEDINGT ändern!
# Generieren z.B. mit:  openssl rand -base64 32
AUTH_SECRET="bitte-aendern-mindestens-32-zeichen-langer-geheimer-schluessel"

# LOGIN KOMPLETT DEAKTIVIERT:
# Solange dies NICHT auf "false" steht, ist GAR KEINE Anmeldung nötig — jede
# Person mit der URL hat vollen Admin-Zugriff. Nur für interne/Test-Zwecke!
# Zum echten Schutz (Login wieder aktiv): AUTH_DISABLED="false"
AUTH_DISABLED="true"

# OFFENER LOGIN (greift nur, wenn AUTH_DISABLED="false"):
# Solange dies NICHT auf "false" steht, wird JEDE E-Mail/Passwort-Kombination
# akzeptiert. Zum echten Schutz auf "false" setzen.
AUTH_ALLOW_ANY="true"

# ─── Erster Team-Admin (wird beim Seed angelegt) ───────────────────────────────
SEED_ADMIN_EMAIL="team@laemu.ch"
SEED_ADMIN_PASSWORD="laemu-team-2026"
SEED_ADMIN_NAME="LAEMU Team"

# ─── Selbst-Registrierung ──────────────────────────────────────────────────────
# Gemeinsamer Code, mit dem sich neue Team-Mitglieder selbst registrieren können
# (Rolle: Redaktion). Nur wer diesen Code kennt, kann ein Konto erstellen.
# Leer lassen, um die Selbst-Registrierung zu deaktivieren (Konten dann nur über
# die Team-Verwaltung durch Admins). Ausnahme: Solange noch kein Konto existiert,
# darf der erste Account (Admin) ohne Code angelegt werden.
TEAM_REGISTRATION_CODE="laemu-team-beitritt"
